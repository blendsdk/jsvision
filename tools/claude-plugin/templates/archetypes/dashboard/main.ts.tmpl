import { pathToFileURL } from 'node:url';

import {
  Button,
  col,
  Commands,
  createApplication,
  fixed,
  ProgressBar,
  row,
  signal,
  Spinner,
  statusItem,
  statusLine,
  Window,
  type Application,
} from '@jsvision/ui';

/**
 * Build the __SLUG__ application: a {@link ProgressBar} and a {@link Spinner} bound to signals, driven
 * by Step / Reset buttons. Returns the assembled application *without* connecting to a terminal, so it
 * can be mounted headlessly in a test. To advance on a timer instead of a button, bump the signals on
 * each tick and emit a no-op command so the loop repaints once (see the jsvision skill's live-dashboard
 * recipe and its `runSpinner` helper).
 *
 * @returns The ready-to-run application.
 * @example
 * const app = buildApp();
 * await app.run(); // on an interactive terminal
 */
export function buildApp(): Application {
  const app = createApplication({
    statusLine: statusLine([statusItem('~Alt-X~ Exit', Commands.quit, 'Alt+X')]),
  });

  const value = signal(0); // progress fraction in [0, 1]
  const frame = signal(0); // spinner frame index

  const bar = new ProgressBar({ value, caption: true, label: 'Progress', labelPosition: 'left' });
  const spinner = new Spinner({ frame, preset: 'dots', label: () => (value() >= 1 ? 'Done' : 'Working…') });

  const step = new Button('~S~tep', { command: 'step' });
  const reset = new Button('~R~eset', { command: 'reset' });
  // Command handlers run inside a dispatch tick, so these signal writes repaint automatically — no
  // manual flush needed (a signal write from a bare timer would; see the recipe).
  app.onCommand('step', () => {
    value.set(Math.min(1, Math.round((value() + 0.1) * 10) / 10));
    frame.set(frame() + 1);
  });
  app.onCommand('reset', () => {
    value.set(0);
    frame.set(0);
  });

  const win = new Window('__SLUG__');
  win.layout.rect = { x: 2, y: 2, width: 46, height: 10 };
  // A bar over a spinner over a button row, composed with the layout DSL.
  win.add(
    col(
      { gap: 1 },
      fixed(bar, 1),
      fixed(spinner, 1),
      fixed(row({ gap: 2 }, fixed(step, 10), fixed(reset, 11)), 2),
    ),
  );
  app.desktop.addWindow(win);

  return app;
}

/** Connect to the terminal and run until quit, unless there is no interactive TTY. */
async function run(): Promise<number> {
  if (process.stdout.isTTY !== true) {
    process.stdout.write('This app needs an interactive terminal (TTY).\n');
    return 0;
  }
  return buildApp().run();
}

// Auto-run only when this file is executed directly (e.g. `tsx src/main.ts`), never when imported by
// a test — importing must not connect to a terminal or exit the process.
if (process.argv[1] !== undefined && import.meta.url === pathToFileURL(process.argv[1]).href) {
  void run().then((code) => process.exit(code));
}
