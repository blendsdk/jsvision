{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["TUI_SKIP_PERF"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build", "^build"]
    },
    "test:e2e": {
      "dependsOn": ["build", "^build"]
    },
    "check:deps": {
      "dependsOn": ["build"]
    },
    "check:docs": {}
  }
}
