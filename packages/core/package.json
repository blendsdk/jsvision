{
  "name": "@jsvision/core",
  "version": "0.2.0",
  "description": "Pure, zero-dependency foundation engine for classic terminal (TUI) applications",
  "keywords": [
    "tui",
    "terminal",
    "cli",
    "ansi",
    "console",
    "text-mode",
    "screen-buffer",
    "capability-detection",
    "typescript"
  ],
  "homepage": "https://github.com/blendsdk/jsvision#readme",
  "bugs": "https://github.com/blendsdk/jsvision/issues",
  "license": "MIT",
  "author": "TrueSoftware B.V. <gevik@truesoftware.nl>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blendsdk/jsvision.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "types": "./dist/engine/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/engine/index.d.ts",
      "import": "./dist/engine/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "check:deps": "node ../../scripts/check-no-native-deps.mjs .",
    "check:docs": "node ../../scripts/check-jsdoc.mjs .",
    "bench": "tsx bench/frame-bench.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@xterm/headless": "^6.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "vitest": "^4.1.10"
  }
}
