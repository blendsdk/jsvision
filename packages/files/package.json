{
  "name": "@jsvision/files",
  "version": "0.1.1",
  "description": "jsvision files — a classic file-system dialog family (FileDialog/ChDirDialog + FileList/DirList/FileInput/FileInfoPane) for @jsvision/ui.",
  "keywords": [
    "tui",
    "terminal",
    "file-dialog",
    "file-browser",
    "widgets",
    "text-mode",
    "typescript"
  ],
  "homepage": "https://github.com/blendsdk/jsvision#readme",
  "bugs": "https://github.com/blendsdk/jsvision/issues",
  "license": "MIT",
  "author": "TrueSoftware B.V. <gevik@truesoftware.nl>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blendsdk/jsvision.git",
    "directory": "packages/files"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e --passWithNoTests",
    "check:deps": "node ../../scripts/check-no-native-deps.mjs .",
    "check:docs": "node ../../scripts/check-jsdoc.mjs ."
  },
  "dependencies": {
    "@jsvision/core": "0.1.1",
    "@jsvision/ui": "0.1.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "vitest": "^4.1.10"
  }
}
