    "probe": "tsx capability-probe/main.ts",
    "demo:resize": "tsx resize-demo/main.ts",
    "demo:playground": "tsx keyboard-mouse-playground/main.ts",
    "demo:reactive": "tsx reactive-demo/main.ts",
    "demo:layout": "tsx layout-demo/main.ts",
    "demo:layout-dsl": "tsx layout-dsl-playground/main.ts",
    "demo:view": "tsx view-demo/main.ts",
    "demo:events": "tsx event-demo/main.ts",
    "demo:shell": "tsx shell-demo/main.ts",
    "demo:controls": "tsx controls-demo/main.ts",
    "demo:router": "tsx router-demo/main.ts",
    "demo:containers": "tsx containers-demo/main.ts",
    "demo:tree": "tsx tree-demo/main.ts",
    "demo:table": "tsx table-demo/main.ts",
    "demo:tabs": "tsx tabs-demo/main.ts",
    "demo:feedback": "tsx feedback-demo/main.ts",
    "demo:date": "tsx date-demo/main.ts",
    "demo:color": "tsx color-demo/main.ts",
    "demo:surface": "tsx surface-demo/main.ts",
    "demo:themes": "tsx themes-demo/main.ts",
    "demo:files": "tsx files-demo/main.ts",
    "demo:dropdowns": "tsx dropdowns-demo/main.ts",
    "demo:controls-live": "tsx controls-live/main.ts",
    "demo:kitchen": "tsx kitchen-sink/main.ts",
    "demo:tvision": "tsx tvision-demo/main.ts",
    "demo:chrome-bars": "tsx chrome-bars-demo/main.ts",
    "demo:amiga-clock": "tsx amiga-clock/main.ts",
    "demo:matrix": "tsx matrix-rain/main.ts",
    "demo:web": "vite --config web-xterm/vite.config.ts",
    "demo:editor": "tsx editor-demo/main.ts",
    "demo:tvedit": "tsx tvedit-demo/main.ts",
    "playground": "tsx --watch playground/main.ts"
  },
  "dependencies": {
    "@jsvision/core": "0.2.0",
    "@jsvision/files": "0.2.0",
    "@jsvision/forms": "0.2.0",
    "@jsvision/ui": "0.2.0",
    "@jsvision/web": "0.2.0",
