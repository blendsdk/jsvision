{
  "name": "@jsvision/examples",
  "private": true,
  "version": "0.2.0",
  "description": "Dev-only runnable examples + probe harness for @jsvision/core (never published)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blendsdk/jsvision.git",
    "directory": "packages/examples"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
