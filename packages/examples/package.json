  "devDependencies": {
    "@types/node": "^26.1.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "tsx": "^4.23.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
