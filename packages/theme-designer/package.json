{
  "name": "@jsvision/theme-designer",
  "version": "0.1.1",
  "private": true,
  "description": "jsvision theme designer — a standalone terminal app for authoring @jsvision/core themes (live preview, RGB/hex/swatch color picking, WCAG contrast, depth downsampling, presets, JSON import/export). Built from the widgets it themes. Private until first release.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blendsdk/jsvision.git",
    "directory": "packages/theme-designer"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e --passWithNoTests",
    "check:deps": "node ../../scripts/check-no-native-deps.mjs ."
  },
  "dependencies": {
    "@jsvision/core": "0.1.1",
    "@jsvision/ui": "0.1.1",
    "@jsvision/files": "0.1.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "vitest": "^4.1.10"
  }
}
